model Transaction {
  id          Int    @id @default(autoincrement())
  description String
  amount      String
  type        TransactionType
  assetId     Int    @map("assetId")
  asset       Asset  @relation(fields: [assetId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  expense
  income
}